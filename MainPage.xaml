<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Maui.MathGame.MainPage"
             >
    <ContentView>
        <VerticalStackLayout
            Spacing="25"
            Padding="50"
            >
            <Label 
                Text="welcome to math game!"
                HorizontalTextAlignment="Center"
                FontSize="50"
                TextColor="Black"/>
            <Label 
                Text="what game would u like to play"
                HorizontalTextAlignment="Center"
                FontSize="50"/>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Text="+"
                        Margin="5"
                        Clicked="OnGameChosen"
                        FontSize="60"
                        MaximumWidthRequest="100"
                        BackgroundColor="Purple"/>
                <Button Grid.Column="1"
                        Text="-"
                        Margin="5"
                        Clicked="OnGameChosen"
                        MaximumWidthRequest="100"
                        FontSize="60"
                         BackgroundColor="Purple"/>
                <Button Grid.Column="2"
                        Text="x"
                        Margin="5"
                        Clicked="OnGameChosen"
                        FontSize="60"
                        MaximumWidthRequest="100"
                         BackgroundColor="Purple"/>
                <Button Grid.Column="3"
                        Text="/"
                        Margin="5"
                        Clicked="OnGameChosen"
                        FontSize="60"
                        MaximumWidthRequest="100"
                         BackgroundColor="Purple"/>
                <Button Grid.Row ="1"
                        Grid.ColumnSpan="4"
                        BackgroundColor="ForestGreen"
                        Text="Previous Games"
                        Clicked="OnViewPreviousGameChosen"
                        FontSize="32"
                        MaximumWidthRequest="300"
                        MaximumHeightRequest="70"/>
            </Grid>
        </VerticalStackLayout>
    </ContentView>
</ContentPage>
